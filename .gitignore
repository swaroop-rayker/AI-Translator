# === AI Translator Global Gitignore ===

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script run from a template
#  before PyInstaller builds the exe, so you can ignore these
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.toh/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/
.tox/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# PEP 582; project packages directory (e.g. pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Virtual Environments
.venv/
venv/
ENV/
env/
ENV/
pyvenv.cfg
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if platform-specific dependencies are used,
#   it may cause troubles, so use your judgment.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but may be ignored
#   in library projects.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions
# pdm.lock

# NodeJS / React Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vite build output
dist/
out/
build/

# Local databases and binaries
*.db
*.sqlite
torch-*.whl
*.whl

# Application Data & ML Checkpoints
data/
*.csv
*.txt
*.jsonl
*.safetensors
*.bin
*.pt
*.pkl
*.signal

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
